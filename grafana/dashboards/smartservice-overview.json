{
  "title": "SmartService - API Overview",
  "uid": "smartservice-overview",
  "panels": [
    {
      "title": "QPS by Intent",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(smartservice_chat_request_total[5m])) by (intent)", "legendFormat": "{{intent}}"}
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {"expr": "sum(rate(smartservice_chat_request_total{status='error'}[5m])) / sum(rate(smartservice_chat_request_total[5m]))"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "title": "Latency P50/P95/P99",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(smartservice_chat_request_duration_seconds_bucket[5m]))", "legendFormat": "P50"},
        {"expr": "histogram_quantile(0.95, rate(smartservice_chat_request_duration_seconds_bucket[5m]))", "legendFormat": "P95"},
        {"expr": "histogram_quantile(0.99, rate(smartservice_chat_request_duration_seconds_bucket[5m]))", "legendFormat": "P99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "LLM Token Usage",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(smartservice_llm_token_usage_total[5m])) by (agent_name, type)", "legendFormat": "{{agent_name}} {{type}}"}
      ]
    },
    {
      "title": "LLM Call Latency by Agent",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(smartservice_llm_call_duration_seconds_bucket[5m])) by (agent_name)", "legendFormat": "{{agent_name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Tool Call Success vs Failure",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(smartservice_tool_call_total{status='success'}[5m])) by (tool_name)", "legendFormat": "{{tool_name}} success"},
        {"expr": "sum(rate(smartservice_tool_call_total{status='failed'}[5m])) by (tool_name)", "legendFormat": "{{tool_name}} fail"}
      ]
    },
    {
      "title": "RAG Retrieval Latency",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(smartservice_rag_retrieval_duration_seconds_bucket[5m]))", "legendFormat": "P95"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Circuit Breaker Status",
      "type": "state-timeline",
      "targets": [
        {"expr": "smartservice_circuit_breaker_state", "legendFormat": "{{adapter_name}}"}
      ]
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "targets": [
        {"expr": "smartservice_active_sessions"}
      ]
    },
    {
      "title": "Rate Limit Hits",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(smartservice_rate_limit_hits_total[5m])) by (endpoint)", "legendFormat": "{{endpoint}}"}
      ]
    },
    {
      "title": "Input Guard Blocks",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(smartservice_input_guard_blocks_total[5m])) by (reason)", "legendFormat": "{{reason}}"}
      ]
    },
    {
      "title": "Pod CPU/Memory",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(container_memory_usage_bytes{namespace='smartservice'}) by (pod)", "legendFormat": "{{pod}} mem"},
        {"expr": "sum(rate(container_cpu_usage_seconds_total{namespace='smartservice'}[5m])) by (pod)", "legendFormat": "{{pod}} cpu"}
      ]
    }
  ],
  "schemaVersion": 37
}
