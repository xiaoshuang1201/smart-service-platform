# SmartService 企业版环境变量配置

# ─── LLM (阿里云 DashScope) ─────────────────
DASHSCOPE_API_KEY=sk-your-key-here
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ─── Database ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartservice
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/smartservice

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_BACKEND=single
REDIS_PASSWORD=
# For Sentinel: REDIS_BACKEND=sentinel REDIS_SENTINEL_HOSTS=host1:26379,host2:26379

# ─── Celery ───────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Qdrant ──────────────────────────────────
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_GRPC_PORT=6334

# ─── MinIO ───────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-docs
MINIO_SECURE=false

# ─── OMS / CRM ───────────────────────────────
OMS_VENDOR=mock
# OMS_BASE_URL=http://oms.internal:9001/api
# OMS_API_KEY=xxx
CRM_VENDOR=mock
# CRM_BASE_URL=http://crm.internal:9002/api
# CRM_API_KEY=xxx

# ─── Observability ───────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── Security ────────────────────────────────
API_KEY=change-me-in-production
CORS_ORIGINS=*

# ─── App ─────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
